; Engine configuration file.
; FPS Game - Godot 4.6

config_version=5

[application]

config/name="AluxStrike"
run/main_scene="res://scenes/root.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

Crash="*res://scripts/crash_reporter.gd"
Net="*res://scripts/net/network_manager.gd"
Match="*res://scripts/match.gd"
Settings="*res://scripts/settings.gd"

[debug]

file_logging/enable_file_logging=true
file_logging/enable_file_logging.pc=true
file_logging/log_path="user://logs/godot.log"
file_logging/max_log_files=10
settings/crash_handler/message="AluxStrike crashed. A full log (with backtrace) was saved under: %APPDATA%\\Godot\\app_userdata\\AluxStrike\\logs\\ (editor) or %APPDATA%\\AluxStrike\\logs\\ (exported). Please send the newest crash_*.log / godot.log."
gdscript/warnings/exclude_addons=true

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/per_pixel_transparency/allowed=true

[rendering]

scaling_3d/scale=0.8
anti_aliasing/quality/msaa_3d=0
lights_and_shadows/directional_shadow/size=2048
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=0
